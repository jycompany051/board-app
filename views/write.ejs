<!DOCTYPE html>
<html lang="ko">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>글쓰기</title>
  <link rel="stylesheet" href="/public/style.css" />
  <link href="https://cdn.quilljs.com/1.3.6/quill.snow.css" rel="stylesheet" />
</head>
<body>
  <div class="page narrow">
    <header class="sub-hero">
      <h1>글쓰기</h1>
      <p>글을 작성하고, 나중에 수정할 때 사용할 비밀번호를 함께 입력하세요.</p>
    </header>

    <div class="top-actions">
      <a class="btn" href="/">목록으로</a>
    </div>

    <% if (error) { %>
      <p class="error-text"><%= error %></p>
    <% } %>

    <form method="post" action="/write" class="form-card" onsubmit="return prepareSubmit();">
      <% if (!admin) { %>
        <label class="label">이름 또는 닉네임</label>
        <input type="text" name="author_name" placeholder="이름 또는 닉네임" />
      <% } else { %>
        <label class="label">작성자</label>
        <input type="text" value="관리자" disabled />
      <% } %>

      <label class="label">제목</label>
      <input type="text" name="title" placeholder="제목을 입력하세요" required />

      <label class="label">수정 비밀번호</label>
      <input type="password" name="edit_password" placeholder="이 글을 수정할 때만 사용할 비밀번호" required />

      <label class="label">내용</label>
      <div id="editor"></div>
      <input type="hidden" name="content" id="contentInput" />

      <button type="submit" class="btn primary full">등록하기</button>
    </form>
  </div>

  <script src="https://cdn.quilljs.com/1.3.6/quill.min.js"></script>
  <script>
    const quill = new Quill('#editor', {
      theme: 'snow',
      placeholder: '내용을 입력하세요',
      modules: {
        toolbar: [
          [{ header: [1, 2, false] }],
          [{ size: ['small', false, 'large', 'huge'] }],
          ['bold', 'italic', 'underline', 'strike'],
          [{ color: [] }, { background: [] }],
          [{ align: [] }],
          [{ list: 'ordered' }, { list: 'bullet' }],
          ['clean']
        ]
      }
    });

    function prepareSubmit() {
      const html = quill.root.innerHTML.trim();
      document.getElementById('contentInput').value = html;
      return true;
    }
  </script>
</body>
</html>
