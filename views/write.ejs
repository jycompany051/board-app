<!DOCTYPE html>
<html lang="ko">
<head>
  <meta charset="UTF-8" />
  <title>후기 남기기</title>
  <link rel="stylesheet" href="/public/style.css" />
</head>
<body>
  <div class="page narrow">
    <h1>후기 남기기</h1>
    <a class="btn" href="/">목록으로</a>

    <br /><br />

    <% if (error) { %>
      <p class="error-text"><%= error %></p>
    <% } %>

    <form method="post" action="/write" class="form-card">
      <input type="text" name="author_name" placeholder="이름 또는 닉네임" />
      <br /><br />
      <input type="text" name="title" placeholder="제목" required />
      <br /><br />
      <textarea name="content" placeholder="후기를 남겨주세요." required></textarea>
      <br /><br />
      <button type="submit" class="btn primary">등록하기</button>
    </form>
  </div>
</body>
</html>
