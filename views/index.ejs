<!DOCTYPE html>
<html lang="ko">
<head>
  <meta charset="UTF-8" />
  <title>게시판</title>
  <link rel="stylesheet" href="/public/style.css" />
</head>
<body>
  <h1>게시판</h1>

  <div class="top-bar">
    <a class="btn" href="/write">글쓰기</a>

    <% if (admin) { %>
      <a class="btn" href="/change-password">비밀번호 변경</a>

      <form method="post" action="/logout" class="inline-form">
        <button type="submit" class="btn">로그아웃</button>
      </form>
    <% } else { %>
      <a class="btn" href="/login">관리자 로그인</a>
    <% } %>
  </div>

  <hr />

  <h2>글 목록</h2>

  <% if (posts.length === 0) { %>
    <p>등록된 글이 없습니다.</p>
  <% } %>

  <% posts.forEach(post => { %>
    <div class="post">
      <h3><%= post.title %></h3>
      <p><%= post.content %></p>
      <small><%= post.created_at %></small>

      <% if (admin) { %>
        <form method="post" action="/delete/<%= post.id %>">
          <button type="submit">삭제</button>
        </form>
      <% } %>
    </div>
    <hr />
  <% }) %>
</body>
</html>