<!DOCTYPE html>
<html lang="ko">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>글 목록</title>
  <link rel="stylesheet" href="/public/style.css" />
</head>
<body>
  <div class="page">
    <header class="hero simple">
      <h1>글 목록</h1>
      <p>차분한 분위기에서 글을 읽고 남길 수 있는 공간입니다.</p>

      <div class="hero-actions">
        <a class="btn primary" href="/write">글쓰기</a>

        <% if (admin) { %>
          <a class="btn" href="/change-password">비밀번호 변경</a>

          <form method="post" action="/logout" class="inline-form">
            <button type="submit" class="btn danger">로그아웃</button>
          </form>
        <% } else { %>
          <a class="btn" href="/login">관리자 로그인</a>
        <% } %>
      </div>
    </header>

    <section class="review-section">
      <% if (posts.length === 0) { %>
        <div class="empty-box">
          <strong>등록된 글이 없습니다.</strong>
          <p>첫 글을 남겨보세요.</p>
        </div>
      <% } %>

      <div class="review-list">
        <% posts.forEach(post => { %>
          <article class="review-card">
            <div class="review-head">
              <div>
                <h3><%= post.title %></h3>
                <div class="author-line">
                  <span class="author-chip"><%= post.author_name || "익명" %></span>
                </div>
              </div>
            </div>

            <div class="review-content"><%= post.content %></div>

            <div class="review-foot">
              <span><%= new Date(post.created_at).toLocaleString("ko-KR") %></span>

              <% if (admin) { %>
                <form method="post" action="/delete/<%= post.id %>">
                  <button type="submit" class="btn danger small">삭제</button>
                </form>
              <% } %>
            </div>
          </article>
        <% }) %>
      </div>
    </section>
  </div>

  <% if (admin) { %>
    <script>
      const logoutBeacon = () => {
        try {
          navigator.sendBeacon("/logout-beacon");
        } catch (e) {}
      };

      window.addEventListener("beforeunload", logoutBeacon);

      document.addEventListener("visibilitychange", () => {
        if (document.visibilityState === "hidden") {
          logoutBeacon();
        }
      });
    </script>
  <% } %>
</body>
</html>
