<!DOCTYPE html>
<html>
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>글쓰기</title>
<link rel="stylesheet" href="/public/style.css">
<link href="https://cdn.quilljs.com/1.3.6/quill.snow.css" rel="stylesheet">
</head>
<body>

<div class="page narrow">
  <div class="page-title-wrap">
    <h1 class="page-title">글쓰기</h1>
  </div>

  <div class="form-card">
    <% if (error) { %>
      <div class="error-box"><%= error %></div>
    <% } %>

    <form action="/write" method="POST" onsubmit="return prepareSubmit();">
      <% if (!admin) { %>
        <input type="text" name="author_name" placeholder="작성자">
      <% } else { %>
        <input type="text" value="관리자" disabled>
      <% } %>

      <input type="text" name="title" placeholder="제목" required>

      <% if (!admin) { %>
        <input type="password" name="edit_password" placeholder="수정 비밀번호" required>
      <% } %>

      <div id="editor"></div>
      <input type="hidden" name="content" id="contentInput">

      <div class="bottom-btns">
        <% if (admin) { %>
          <label class="notice-toggle">
            <input type="checkbox" name="is_notice">
            <span>공지글</span>
          </label>
        <% } %>

        <button type="submit" class="btn">등록</button>
        <a href="/" class="btn cancel">취소</a>
      </div>
    </form>
  </div>
</div>

<script src="https://cdn.quilljs.com/1.3.6/quill.min.js"></script>
<script>
const quill = new Quill('#editor', {
  theme: 'snow',
  placeholder: '내용을 입력하세요',
  modules: {
    toolbar: [
      [{ header: [1, 2, false] }],
      [{ size: ['small', false, 'large', 'huge'] }],
      ['bold', 'italic', 'underline'],
      [{ color: [] }, { background: [] }],
      [{ align: [] }],
      [{ list: 'ordered' }, { list: 'bullet' }],
      ['clean']
    ]
  }
});

function prepareSubmit() {
  document.getElementById('contentInput').value = quill.root.innerHTML;
  return true;
}
</script>

</body>
</html>
