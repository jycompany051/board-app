<!DOCTYPE html>
<html>
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>비밀번호 변경</title>
<link rel="stylesheet" href="/public/style.css">
</head>
<body>

<div class="page narrow">
  <div class="page-title-wrap">
    <h1 class="page-title">비밀번호 변경</h1>
  </div>

  <div class="form-card">
    <% if (error) { %>
      <div class="error-box"><%= error %></div>
    <% } %>

    <% if (success) { %>
      <div class="success-box"><%= success %></div>
    <% } %>

    <form action="/change-password" method="POST">
      <input type="password" name="currentPassword" placeholder="현재 비밀번호" required>
      <input type="password" name="newPassword" placeholder="새 비밀번호" required>
      <input type="password" name="confirmPassword" placeholder="새 비밀번호 확인" required>

      <div class="bottom-btns">
        <button type="submit" class="btn">비밀번호 변경</button>
        <a href="/" class="btn cancel">취소</a>
      </div>
    </form>
  </div>
</div>

</body>
</html>
