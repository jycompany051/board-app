<!DOCTYPE html>
<html lang="ko">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>상담 후기글</title>
  <link rel="stylesheet" href="/public/style.css" />
</head>
<body>
  <div class="page">
    <header class="hero simple">
      <div class="top-bar">
        <div class="top-bar-left">
          <h1>상담 후기글</h1>
          <p>상담 관련 글을 확인할 수 있는 게시판입니다.</p>
        </div>

        <div class="top-bar-right top-bar-column">
          <% if (admin) { %>
            <div class="admin-status">관리자 로그인 상태</div>
            <a class="btn" href="/change-password">비밀번호 변경</a>
            <form method="post" action="/logout" class="inline-form">
              <button type="submit" class="btn danger">로그아웃</button>
            </form>
          <% } else { %>
            <a class="btn" href="/login">관리자 로그인</a>
          <% } %>

          <a class="btn primary" href="/write">글쓰기</a>
        </div>
      </div>
    </header>

    <section class="list-box">
      <div class="list-top">
        <div>전체 : <strong><%= posts.length %></strong></div>
      </div>

      <table class="board-table">
        <thead>
          <tr>
            <th class="col-no">번호</th>
            <th>제목</th>
            <th class="col-author">작성자</th>
            <th class="col-date">등록일</th>
          </tr>
        </thead>
        <tbody>
          <% if (posts.length === 0) { %>
            <tr>
              <td colspan="4" class="empty-row">등록된 글이 없습니다.</td>
            </tr>
          <% } %>

          <% posts.forEach(post => { %>
            <tr>
              <td class="col-no"><%= post.id %></td>
              <td class="title-cell">
                <a href="/post/<%= post.id %>"><%= post.title %></a>
                <% if (post.comment_count > 0) { %>
                  <span class="comment-count">[<%= post.comment_count %>]</span>
                <% } %>
              </td>
              <td class="col-author"><%= post.author_name || "익명" %></td>
              <td class="col-date"><%= new Date(post.created_at).toLocaleDateString("ko-KR") %></td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    </section>
  </div>

  <% if (admin) { %>
    <script>
      window.addEventListener("beforeunload", () => {
        try {
          navigator.sendBeacon("/logout-beacon");
        } catch (e) {}
      });
    </script>
  <% } %>
</body>
</html>
