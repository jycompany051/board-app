<!DOCTYPE html>
<html>
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title><%= post.title %></title>
<link rel="stylesheet" href="/style.css">
</head>
<body>

<div class="page narrow">

  <div class="top-actions top-actions-right">
    <% if (admin) { %>

      <span class="admin-status">관리자 로그인 상태</span>

      <a href="/change-password" class="btn">비밀번호 변경</a>

      <form action="/logout" method="POST" class="inline-form">
        <button type="submit" class="btn logout">로그아웃</button>
      </form>

    <% } else { %>
      <a href="/login" class="btn">관리자 로그인</a>
    <% } %>
  </div>

  <div class="page-title-wrap">
    <h1 class="page-title">상담문의</h1>
  </div>

  <div class="detail-card">
    <h2 class="detail-title"><%= post.title %></h2>

    <div class="detail-meta">
      <span>작성자: <%= post.author_name %></span>
      <span>등록일: <%= new Date(post.created_at).toLocaleString("ko-KR") %></span>
    </div>

    <div class="detail-content">
      <%- post.content_html %>
    </div>

    <div class="bottom-btns">
      <a href="/" class="btn cancel">목록</a>

      <% if (!admin) { %>
        <a href="/edit/<%= post.id %>" class="btn">수정</a>
      <% } %>

      <% if (admin) { %>
        <form action="/delete/<%= post.id %>" method="POST" class="inline-form">
          <button type="submit" class="btn delete">삭제</button>
        </form>
      <% } %>
    </div>
  </div>

  <div class="detail-card">
    <h2 class="detail-title">댓글</h2>

    <% if (admin) { %>
      <form action="/comment/<%= post.id %>" method="POST">
        <textarea name="content" placeholder="댓글을 입력하세요" required></textarea>

        <div class="bottom-btns">
          <button type="submit" class="btn">댓글 등록</button>
        </div>
      </form>
    <% } %>

    <% if (comments && comments.length > 0) { %>
      <% comments.forEach(function(comment) { %>
        <div class="comment-block">
          <div class="detail-meta">
            <span>작성자: <%= comment.author_name %></span>
            <span>등록일: <%= new Date(comment.created_at).toLocaleString("ko-KR") %></span>
          </div>

          <div class="detail-content">
            <%= comment.content %>
          </div>

          <% if (admin) { %>
            <form action="/reply/<%= post.id %>/<%= comment.id %>" method="POST">
              <textarea name="content" placeholder="답글을 입력하세요" required></textarea>

              <div class="bottom-btns">
                <button type="submit" class="btn">답글 등록</button>
              </div>
            </form>
          <% } %>

          <% const replies = replyMap.get(comment.id) || []; %>
          <% if (replies.length > 0) { %>
            <% replies.forEach(function(reply) { %>
              <div class="reply-block">
                <div class="detail-meta">
                  <span>작성자: <%= reply.author_name %></span>
                  <span>등록일: <%= new Date(reply.created_at).toLocaleString("ko-KR") %></span>
                </div>

                <div class="detail-content">
                  <%= reply.content %>
                </div>
              </div>
            <% }) %>
          <% } %>
        </div>
      <% }) %>
    <% } else { %>
      <div class="detail-content">등록된 댓글이 없습니다.</div>
    <% } %>
  </div>

</div>

<% if (admin) { %>
<script>
(function () {
  let allowNavigation = false;

  document.addEventListener("click", function (e) {
    const link = e.target.closest("a");
    const button = e.target.closest("button");
    const form = e.target.closest("form");

    if (link || form || button) {
      allowNavigation = true;
    }
  });

  window.addEventListener("beforeunload", function () {
    if (!allowNavigation) {
      try {
        navigator.sendBeacon("/logout-beacon");
      } catch (e) {}
    }
  });
})();
</script>
<% } %>

</body>
</html>
