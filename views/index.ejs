<h1>게시판</h1>

<% if(admin){ %>
<form action="/logout" method="POST">
<button>로그아웃</button>
</form>
<% } else { %>
<a href="/login">관리자 로그인</a>
<% } %>

<a href="/write">글쓰기</a>

<table>
<% posts.forEach((p)=>{ %>
<tr>
<td><a href="/post/<%= p.id %>"><%= p.title %></a></td>
<td><%= p.author_name %></td>
</tr>
<% }) %>
</table>
