<!DOCTYPE html>
<html>
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>상담 후기글</title>
<link rel="stylesheet" href="/public/style.css">
</head>
<body>

<div class="page">

  <div class="top-actions top-actions-right">
    <% if (admin) { %>
      <span class="admin-status">관리자 로그인 상태</span>

      <a href="/change-password" class="btn">비밀번호 변경</a>

      <form action="/logout" method="POST" class="inline-form">
        <button type="submit" class="btn logout">로그아웃</button>
      </form>

    <% } else { %>
      <a href="/login" class="btn">관리자 로그인</a>
    <% } %>
  </div>

  <div class="page-title-wrap">
    <h1 class="page-title">상담 후기글</h1>
    <p class="page-desc">상담 후기 글을 확인 할 수 있는 게시판 입니다.</p>
  </div>

  <div class="list-card">

    <div class="list-top">
      <span>전체 : <%= totalCount %></span>

      <form action="/" method="GET" class="search-form">
        <input
          type="text"
          name="q"
          value="<%= q || '' %>"
          placeholder="검색어"
          class="search-input"
        >
        <button type="submit" class="btn search-btn">검색하기</button>
      </form>
    </div>

    <table class="board-table">
      <thead>
        <tr>
          <th>번호</th>
          <th>제목</th>
          <th>작성자</th>
          <th>등록일</th>
        </tr>
      </thead>

      <tbody>
        <% if (posts.length === 0) { %>
          <tr>
            <td colspan="4" class="empty-cell">등록된 글이 없습니다.</td>
          </tr>
        <% } %>

        <% posts.forEach(post => { %>
          <tr>
            <td><%= post.id %></td>

            <td class="title-cell">
              <a href="/post/<%= post.id %>" class="title-link">
                <%= post.title %>
              </a>

              <% if (!post.checked_by_admin) { %>
                <span class="new-badge">NEW</span>
              <% } %>

              <% if (post.comment_count > 0) { %>
                <span class="comment-count">[댓글 <%= post.comment_count %>]</span>
              <% } %>

              <% if (post.reply_previews && post.reply_previews.length > 0) { %>
                <div class="reply-preview-list">
                  <% post.reply_previews.forEach(reply => { %>
                    <div class="reply-preview-item">
                      <span class="reply-preview-prefix">└ 답글</span>
                      <span><%= reply.content %></span>
                    </div>
                  <% }) %>
                </div>
              <% } %>
            </td>

            <td><%= post.author_name %></td>

            <td>
              <%= new Date(post.created_at).toLocaleDateString("ko-KR") %>
            </td>
          </tr>
        <% }) %>
      </tbody>
    </table>

    <% if (pagination && pagination.totalPages > 1) { %>
      <div class="pagination">
        <% if (pagination.hasPrev) { %>
          <a
            href="/?page=<%= pagination.prevPage %><%= q ? '&q=' + encodeURIComponent(q) : '' %>"
            class="page-link"
          >
            이전
          </a>
        <% } %>

        <% for (let i = pagination.startPage; i <= pagination.endPage; i++) { %>
          <a
            href="/?page=<%= i %><%= q ? '&q=' + encodeURIComponent(q) : '' %>"
            class="page-link <%= i === pagination.currentPage ? 'active' : '' %>"
          >
            <%= i %>
          </a>
        <% } %>

        <% if (pagination.hasNext) { %>
          <a
            href="/?page=<%= pagination.nextPage %><%= q ? '&q=' + encodeURIComponent(q) : '' %>"
            class="page-link"
          >
            다음
          </a>
        <% } %>
      </div>
    <% } %>

  </div>
</div>

<% if (admin) { %>
<script>
(function () {
  let allowNavigation = false;

  document.addEventListener("click", function (e) {
    const link = e.target.closest("a");
    const button = e.target.closest("button");
    const form = e.target.closest("form");

    if (link || form || button) {
      allowNavigation = true;
    }
  });

  window.addEventListener("beforeunload", function () {
    if (!allowNavigation) {
      try {
        navigator.sendBeacon("/logout-beacon");
      } catch (e) {}
    }
  });
})();
</script>
<% } %>

</body>
</html>
