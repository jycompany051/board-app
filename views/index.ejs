<!DOCTYPE html>
<html>
<head>
<meta charset="UTF-8">
<title>상담 후기글</title>
<link rel="stylesheet" href="/public/style.css">
</head>
<body>

<div class="top-bar">
  <% if (admin) { %>
    <span class="admin-status">관리자 로그인 상태</span>
    <a href="/change-password" class="btn">비밀번호 변경</a>
    <form action="/logout" method="POST" style="display:inline;">
      <button class="btn logout">로그아웃</button>
    </form>
  <% } else { %>
    <a href="/login" class="btn">관리자 로그인</a>
  <% } %>
</div>

<h1>상담 후기글</h1>

<div class="container">

  <div class="header-row">
    <span>전체 : <%= posts.length %></span>

    <a href="/write" class="btn write-btn">글쓰기</a>
  </div>

  <table>
    <tr>
      <th>번호</th>
      <th>제목</th>
      <th>작성자</th>
      <th>등록일</th>
    </tr>

    <% posts.forEach((post, index) => { %>
      <tr>
        <td><%= posts.length - index %></td>
        <td>
          <a href="/post/<%= post.id %>">
            <%= post.title %>
            <% if(post.comment_count > 0){ %>
              [<%= post.comment_count %>]
            <% } %>
          </a>
        </td>
        <td><%= post.author_name %></td>
        <td><%= new Date(post.created_at).toLocaleDateString() %></td>
      </tr>
    <% }) %>

  </table>

</div>

</body>
</html>
