<!DOCTYPE html>
<html>
<head>
<meta charset="UTF-8">
<title><%= post.title %></title>
<link rel="stylesheet" href="/public/style.css">
</head>
<body>

<div class="top-bar">
  <% if (admin) { %>
    <span>관리자 로그인 상태</span>
    <a href="/change-password" class="btn">비밀번호 변경</a>
    <form action="/logout" method="POST" style="display:inline;">
      <button class="btn logout">로그아웃</button>
    </form>
  <% } %>
</div>

<div class="container">

  <h2><%= post.title %></h2>

  <div class="meta">
    작성자: <%= post.author_name %> |
    등록일: <%= new Date(post.created_at).toLocaleString() %>
  </div>

  <div class="content">
    <%- post.content_html %>
  </div>

  <div class="bottom-btns">
    <a href="/" class="btn">목록</a>
    <a href="/edit/<%= post.id %>" class="btn">수정</a>

    <% if (admin) { %>
      <form action="/delete/<%= post.id %>" method="POST">
        <button class="btn delete">삭제</button>
      </form>
    <% } %>
  </div>

  <% if (admin) { %>
  <div class="comment-box">
    <form action="/comment/<%= post.id %>" method="POST">
      <textarea name="content" placeholder="댓글 작성"></textarea>
      <button class="btn">댓글</button>
    </form>
  </div>
  <% } %>

</div>

</body>
</html>
