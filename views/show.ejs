<!DOCTYPE html>
<html lang="ko">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= post.title %></title>
  <link rel="stylesheet" href="/style.css" />
</head>
<body>
  <!--
    ============================================================
    기존 상세보기 화면의 상단/본문/UI는 그대로 둔다는 전제입니다.
    아래 구조에서 "기존 상세보기 영역" 부분은 현재 사용 중인 마크업 그대로 두고,
    그 아래에 댓글 섹션만 추가하면 됩니다.
    ============================================================
  -->

  <div class="detail-wrap">
    <!-- 기존 상세보기 영역 시작 -->
    <div class="detail-view">
      <h1><%= post.title %></h1>

      <% if (post.author) { %>
        <div><%= post.author %></div>
      <% } %>

      <% if (post.createdAt) { %>
        <div>
          <%= new Date(post.createdAt).toLocaleString("ko-KR") %>
        </div>
      <% } %>

      <div>
        <%- String(post.content || "").replace(/\n/g, "<br>") %>
      </div>
    </div>
    <!-- 기존 상세보기 영역 끝 -->

    <!-- ========================================================= -->
    <!-- 댓글 영역 추가 시작 -->
    <!-- ========================================================= -->
    <div class="comments-section">
      <h3>댓글</h3>

      <% if (isAdmin) { %>
        <form method="POST" action="/posts/<%= post.id %>/comments">
          <input type="hidden" name="admin" value="1" />
          <textarea
            name="content"
            rows="3"
            placeholder="댓글을 입력하세요"
            required
          ></textarea>
          <button type="submit">댓글 등록</button>
        </form>
      <% } %>

      <% if (post.comments && post.comments.length > 0) { %>
        <% post.comments.forEach(function(comment) { %>
          <div class="comment-item">
            <div class="comment-meta">
              <strong><%= comment.author || "관리자" %></strong>
              <% if (comment.createdAt) { %>
                <span><%= new Date(comment.createdAt).toLocaleString("ko-KR") %></span>
              <% } %>
            </div>

            <div class="comment-content">
              <%- String(comment.content || "").replace(/\n/g, "<br>") %>
            </div>

            <% if (isAdmin) { %>
              <form method="POST" action="/posts/<%= post.id %>/comments/<%= comment.id %>/replies">
                <input type="hidden" name="admin" value="1" />
                <textarea
                  name="content"
                  rows="2"
                  placeholder="답글을 입력하세요"
                  required
                ></textarea>
                <button type="submit">답글 등록</button>
              </form>
            <% } %>

            <!-- 답글: 부모 댓글 바로 아래 -->
            <% if (comment.replies && comment.replies.length > 0) { %>
              <div class="reply-list">
                <% comment.replies.forEach(function(reply) { %>
                  <div class="reply-item">
                    <div class="reply-meta">
                      <strong><%= reply.author || "관리자" %></strong>
                      <% if (reply.createdAt) { %>
                        <span><%= new Date(reply.createdAt).toLocaleString("ko-KR") %></span>
                      <% } %>
                    </div>

                    <div class="reply-content">
                      <%- String(reply.content || "").replace(/\n/g, "<br>") %>
                    </div>
                  </div>
                <% }) %>
              </div>
            <% } %>
          </div>
        <% }) %>
      <% } else { %>
        <div>등록된 댓글이 없습니다.</div>
      <% } %>
    </div>
    <!-- ========================================================= -->
    <!-- 댓글 영역 추가 끝 -->
    <!-- ========================================================= -->
  </div>
</body>
</html>
