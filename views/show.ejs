<h2><%= post.title %></h2>
<p><%= post.author_name %></p>

<div><%- post.content_html %></div>

<a href="/">목록</a>

<hr>

<h3>댓글</h3>

<% if(admin){ %>
<form method="POST" action="/comment/<%= post.id %>">
<textarea name="content"></textarea>
<button>댓글</button>
</form>
<% } %>

<% comments.forEach(c=>{ %>
<div>
<b><%= c.author_name %></b>
<p><%= c.content %></p>

<% if(admin){ %>
<form method="POST" action="/reply/<%= post.id %>/<%= c.id %>">
<textarea name="content"></textarea>
<button>답글</button>
</form>
<% } %>

<% if(replyMap.get(c.id)){ %>
<% replyMap.get(c.id).forEach(r=>{ %>
<div style="margin-left:30px">
<b><%= r.author_name %></b>
<p><%= r.content %></p>
</div>
<% }) %>
<% } %>

</div>
<% }) %>
